{
  "manifest_version": 3,
  "name": "YOMU Watch Tracker",
  "version": "1.1.0",
  "description": "Automatically tracks your anime watch progress and stats on any streaming site.",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "scripting",
    "alarms",
    "idle"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YOMU Watch Tracker"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
